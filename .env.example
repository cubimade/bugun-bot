# ============================================================
#  BUGUN-BOT — muhit o'zgaruvchilari namunasi
#  Bu faylni nusxalab .env qiling va qiymatlarni to'ldiring.
#  Railway'da esa bu o'zgaruvchilarni "Variables" bo'limiga qo'shing.
#  DIQQAT: haqiqiy tokenlarni GitHub'ga YUKLAMANG.
# ============================================================

# --- Claude (Anthropic) API kaliti ---
ANTHROPIC_API_KEY=

# --- Instagram / Meta ---
# Webhook tekshiruvi uchun ixtiyoriy maxfiy so'z (Meta panelida ham shu yoziladi)
VERIFY_TOKEN=

# Asosiy (bitta) akkaunt tokeni. Ko'p akkaunt ishlatilsa — IG_ACCOUNTS'ni to'ldiring.
IG_ACCESS_TOKEN=

# Meta ilovaning App Secret qiymati (App Dashboard → Settings → Basic → App Secret).
# Webhook imzosini (X-Hub-Signature-256) tekshirish uchun — soxta so'rovlardan himoya.
# Qo'yilmasa bot ishlayveradi, lekin imzo tekshirilmaydi (tavsiya: qo'yish).
APP_SECRET=

# --- Ko'p akkaunt (ixtiyoriy) ---
# Bir nechta Instagram akkauntni ulash uchun JSON massiv:
# IG_ACCOUNTS=[{"id":"17841ACCOUNTIDA","name":"Asosiy","token":"IGAA..."},{"id":"17841ACCOUNTIDB","name":"Ikkinchi","token":"IGAA..."}]
IG_ACCOUNTS=

# --- Database (Railway avtomatik beradi) ---
DATABASE_URL=

# --- Xulq sozlamalari ---
# Kommentga javob berilганда komment egasiga avtomatik DM yuborish (true/false)
AUTO_DM_ON_COMMENT=true

# --- Dashboard himoyasi (tavsiya etiladi) ---
# Boshqaruv paneli (/dashboard) va API uchun parol. O'rnatilmasa — ochiq.
DASHBOARD_PASSWORD=

# --- Ish vaqti (ixtiyoriy) ---
# WORK_HOURS_ENABLED=true bo'lsa, ish vaqtidan tashqarida tayyor javob yuboriladi.
WORK_HOURS_ENABLED=false
WORK_START=9
WORK_END=21
TZ_OFFSET=5
# OFF_HOURS_MESSAGE="Ish vaqtimiz tugadi, ertaga javob beramiz"

# --- Spam himoyasi (ixtiyoriy) ---
# Bir foydalanuvchi RATE_LIMIT_WINDOW_MS ichida RATE_LIMIT_MAX dan ko'p yozsa — o'tkaziladi.
RATE_LIMIT_MAX=8
RATE_LIMIT_WINDOW_MS=60000

# --- Server ---
# Railway PORT'ni avtomatik beradi; mahalliy uchun 3000
PORT=3000
